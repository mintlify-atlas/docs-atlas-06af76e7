  "publicApiSurface": [
    "Streamlit web interface",
    "get_threat_model() - Generate STRIDE threat models",
    "get_attack_tree() - Generate attack trees",
    "get_mitigations() - Generate mitigation suggestions",
    "get_dread_assessment() - Perform DREAD risk scoring",
    "get_test_cases() - Generate Gherkin test cases",
    "get_image_analysis() - Analyze architecture diagrams",
    "GitHub repository analysis via GitHub API",
    "Multiple LLM provider integrations (OpenAI, Anthropic, Google AI, Mistral, Groq, Ollama, LM Studio)"
